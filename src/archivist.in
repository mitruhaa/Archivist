#!@PYTHON@

import os
import sys
import signal
import locale
import gettext

VERSION = '@VERSION@'
pkgdatadir = '@pkgdatadir@'
localedir = '@localedir@'

sys.dont_write_bytecode = True

sys.path.insert(1, pkgdatadir)
signal.signal(signal.SIGINT, signal.SIG_DFL)
locale.bindtextdomain('archivist', localedir)
locale.textdomain('archivist')
gettext.install('archivist', localedir)

if __name__ == "__main__":
    import gi

    gi.require_version("Gtk", "4.0")
    gi.require_version("Adw", "1")

    from gi.repository import Gio

    resource = Gio.Resource.load(os.path.join(pkgdatadir, "archivist.gresource"))
    resource._register()

    from archivist import main

    sys.exit(main.main(VERSION))
